{
    "name": "nuxt-app",
    "version": "1.8.7",
    "private": true,
    "scripts": {
        "build": "nuxt build",
        "dev": "concurrently \"nuxt dev\" \"npm run start:db\"",
        "start:db": "cd pocketbase && ./pocketbase serve --http=0.0.0.0:8090",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "format": "prettier --write \"**/*.{js,vue,html,css}\"",
        "release": "release-it",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@mdi/font": "7.4.47",
        "@nuxt/image": "2.0.0",
        "@nuxtjs/i18n": "10.4.0",
        "@types/pdfkit": "0.17.6",
        "@types/qrcode": "1.5.6",
        "@vitejs/plugin-vue": "6.0.7",
        "@vue/test-utils": "2.4.10",
        "concurrently": "10.0.1",
        "echarts": "6.1.0",
        "exceljs": "4.4.0",
        "h3": "1.15.11",
        "happy-dom": "20.10.2",
        "install": "^0.13.0",
        "nuxt": "^4.4.6",
        "pdfkit": "0.18.0",
        "pocketbase": "^0.27.0",
        "prettier": "3.8.3",
        "qrcode": "1.5.4",
        "release-it": "20.2.0",
        "sass": "1.100.0",
        "typescript": "6.0.3",
        "vite": "8.0.16",
        "vitest": "4.1.8",
        "vue": "3.5.35",
        "vue-qrcode-reader": "^5.7.3",
        "vuetify": "4.0.8",
        "vuetify-nuxt-module": "v1.0.0-beta.6"
    },
    "browserslist": [
        "defaults and fully supports es6-module"
    ],
    "packageManager": "yarn@4.14.1",
    "release-it": {
        "$schema": "https://unpkg.com/release-it/schema/release-it.json",
        "git": {
            "tagName": "v${version}",
            "commitMessage": "release v${version}",
            "requireCleanWorkingDir": true,
            "push": true
        }
    }
}
