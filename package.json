{
    "name": "nuxt-app",
    "version": "1.8.2",
    "private": true,
    "scripts": {
        "build": "nuxt build",
        "dev": "concurrently \"nuxt dev\" \"npm run start:db\"",
        "start:db": "cd pocketbase && ./pocketbase serve --http=0.0.0.0:8090",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "nuxt prepare",
        "format": "prettier --write \"**/*.{js,vue,html,css}\"",
        "release": "release-it",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@mdi/font": "7.4.47",
        "@nuxt/image": "2.0.0",
        "@nuxtjs/i18n": "10.2.4",
        "@types/pdfkit": "0.17.5",
        "@types/qrcode": "1.5.6",
        "@vitejs/plugin-vue": "6.0.5",
        "@vue/test-utils": "2.4.6",
        "concurrently": "9.2.1",
        "echarts": "6.0.0",
        "exceljs": "4.4.0",
        "h3": "1.15.11",
        "happy-dom": "20.8.9",
        "install": "^0.13.0",
        "nuxt": "^4.4.2",
        "pdfkit": "0.18.0",
        "pocketbase": "^0.26.8",
        "prettier": "3.8.2",
        "qrcode": "1.5.4",
        "release-it": "20.0.0-1",
        "sass": "1.99.0",
        "typescript": "6.0.2",
        "vite": "8.0.7",
        "vitest": "4.1.3",
        "vue": "3.5.32",
        "vue-qrcode-reader": "^5.7.3",
        "vuetify": "4.0.5",
        "vuetify-nuxt-module": "v1.0.0-beta.2"
    },
    "packageManager": "yarn@4.13.0",
    "release-it": {
        "$schema": "https://unpkg.com/release-it/schema/release-it.json",
        "git": {
            "tagName": "v${version}",
            "commitMessage": "release v${version}",
            "requireCleanWorkingDir": true,
            "push": true
        }
    }
}
